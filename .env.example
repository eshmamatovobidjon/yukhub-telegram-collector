# =============================================================================
# YukHub Telegram Collector — Environment Variables
# =============================================================================
# Copy this file to .env and fill in all required values.
# Never commit .env to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# TELEGRAM  (required)
# Get API_ID and API_HASH from https://my.telegram.org → "API development tools"
# -----------------------------------------------------------------------------
TELEGRAM_API_ID=12345678
TELEGRAM_API_HASH=your_api_hash_here
TELEGRAM_PHONE=+998901234567          # Phone number of the Telegram account with country code

# Path where the Telethon session file is stored.
# Must match the volume mount in docker-compose.yml.
TELEGRAM_SESSION_NAME=sessions/yukhub_session

# -----------------------------------------------------------------------------
# DATABASE  (required)
# In Docker Compose the host is the service name "postgres".
# For local development without Docker: localhost
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql+asyncpg://yukhub:yukhub_secret@postgres:5432/yukhub

# -----------------------------------------------------------------------------
# LLM  (required)
# Default: OpenAI gpt-4o-mini (~$1.50/month at normal load)
#
# To use a self-hosted model instead, set LLM_BASE_URL to the OpenAI-compatible
# endpoint and set LLM_MODEL to the model name your server expects.
#
# Examples:
#   Ollama local:         LLM_BASE_URL=http://host.docker.internal:11434/v1
#                         LLM_MODEL=llama3.1:8b
#   vLLM / llama.cpp:    LLM_BASE_URL=http://your-gpu-server:8080/v1
#                         LLM_MODEL=Meta-Llama-3.1-8B-Instruct
#   LM Studio:           LLM_BASE_URL=http://localhost:1234/v1
#                         LLM_MODEL=lmstudio-community/Meta-Llama-3.1-8B-Instruct-GGUF
# -----------------------------------------------------------------------------
OPENAI_API_KEY=sk-...
LLM_MODEL=gpt-4o-mini
# LLM_BASE_URL=                       # leave unset to use OpenAI

# -----------------------------------------------------------------------------
# DATA RETENTION
# -----------------------------------------------------------------------------
MAX_POST_AGE_DAYS=15                  # posts older than this are deleted
CLEANUP_INTERVAL_HOURS=6             # how often the cleanup job runs

# -----------------------------------------------------------------------------
# PERFORMANCE
# -----------------------------------------------------------------------------
QUEUE_MAX_SIZE=5000                   # asyncio.Queue bound (messages)
PARSER_WORKERS=3                      # concurrent LLM tasks (3 is safe for gpt-4o-mini rate limits)

# -----------------------------------------------------------------------------
# LOGGING
# -----------------------------------------------------------------------------
LOG_LEVEL=INFO                        # DEBUG | INFO | WARNING | ERROR
